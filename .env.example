SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
DJANGO_SETTINGS_MODULE=pharmacy_ai.settings_production
DEMO_PHARMACY_NAME=Pharmacy Alpha
LANGUAGE_COOKIE_NAME=pharmacyai_language
LANGUAGE_COOKIE_AGE=31536000
LANGUAGE_COOKIE_SAMESITE=Lax

# PostgreSQL (production)
POSTGRES_DB=pharmacy_ai
POSTGRES_USER=pharmacy_ai
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=prefer

# Production security defaults
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
LANGUAGE_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin
X_FRAME_OPTIONS=DENY
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
